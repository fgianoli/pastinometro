# Porta esposta sull'host (cambiala se 8000 e' occupata o se NPM punta altrove)
PORT=8000

# true dietro HTTPS (Nginx Proxy Manager + Let's Encrypt). Per test locale http://localhost: false
COOKIE_SECURE=true

# Admin pre-provisionato al primo avvio
ADMIN_USERNAME=admin
ADMIN_EMAIL=gianoli.federico@gmail.com

# Lascia vuoto per generare una password casuale al primo avvio
# (verra' stampata nei log e salvata in data/admin_password.txt).
# Oppure metti la tua password sicura qui per usarla subito.
ADMIN_PASSWORD=
