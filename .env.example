# Porta esposta sull'host (cambiala se 8000 e' occupata o se NPM punta altrove)
PORT=8000

# true dietro HTTPS (Nginx Proxy Manager + Let's Encrypt). Per test locale http://localhost: false
COOKIE_SECURE=true

# Admin pre-provisionato al primo avvio
ADMIN_USERNAME=admin
ADMIN_EMAIL=gianoli.federico@gmail.com

# Lascia vuoto per generare una password casuale al primo avvio
# (verra' stampata nei log e salvata in data/admin_password.txt).
# Oppure metti la tua password sicura qui per usarla subito.
ADMIN_PASSWORD=

# URL pubblico dell'app — usato nei link di reset password via email.
# Lascialo vuoto per usare l'host della richiesta come fallback.
BASE_URL=https://pastinometro.federicogianoli.eu

# ---- SMTP per reset password ----
# Se SMTP_HOST e MAIL_FROM sono vuoti, il reset via email e' DISABILITATO
# (la pagina mostra solo login/logout e non il link "password dimenticata").
#
# Esempi di provider:
#   Gmail SMTP (richiede "App password"):
#     SMTP_HOST=smtp.gmail.com
#     SMTP_PORT=587
#     SMTP_USE_TLS=true
#     SMTP_USER=tuoindirizzo@gmail.com
#     SMTP_PASSWORD=<app-password>
#     MAIL_FROM=Il Pastinometro <tuoindirizzo@gmail.com>
#
#   Resend / Mailgun / Postmark / Sendgrid:
#     SMTP_HOST=smtp.resend.com
#     SMTP_PORT=587
#     SMTP_USE_TLS=true
#     SMTP_USER=resend
#     SMTP_PASSWORD=re_xxx
#     MAIL_FROM=noreply@tuodominio.eu
#
#   SMTP del provider hosting (Aruba/OVH/etc):
#     SMTP_HOST=smtps.aruba.it
#     SMTP_PORT=465
#     SMTP_USE_SSL=true
#     SMTP_USE_TLS=false
#     SMTP_USER=tuoindirizzo@tuodominio.it
#     SMTP_PASSWORD=...
#     MAIL_FROM=Il Pastinometro <noreply@tuodominio.it>
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
